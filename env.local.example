# ===========================================
# 카카오톡 대화 분석기 - API 키 설정
# ===========================================
# 이 파일을 .env.local로 복사하고 API 키를 입력하세요.
# cp env.local.example .env.local
#
# 주의: .env.local 파일은 Git에 커밋되지 않습니다.
# ===========================================

# Z.AI GLM API (기본값) — 모델: glm-4.5
# https://www.z.ai 에서 API 키 발급
ZAI_API_KEY=your_zai_api_key_here

# OpenAI API — 모델: gpt-4o-mini
# https://platform.openai.com 에서 API 키 발급
OPENAI_API_KEY=your_openai_api_key_here

# MiniMax API — 모델: MiniMax-M2.7
# https://www.minimax.io 에서 API 키 발급
MINIMAX_API_KEY=your_minimax_api_key_here

# Perplexity API — 모델: sonar
# https://www.perplexity.ai 에서 API 키 발급
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# xAI Grok API — 모델: grok-4-1-fast-non-reasoning
# https://console.x.ai 에서 API 키 발급
XAI_API_KEY=your_xai_api_key_here

# OpenRouter API
# https://openrouter.ai/keys 에서 API 키 발급
OPENROUTER_API_KEY=your_openrouter_api_key_here
# 사용할 OpenRouter 모델 (기본값: x-ai/grok-4.1-fast)
# 예제 모델: x-ai/grok-4.1-fast, deepseek/deepseek-chat, openai/gpt-4o-mini
# OPENROUTER_MODEL=x-ai/grok-4.1-fast
# 출력 토큰 한계 (최대 30000) / 입력 문자 수 한계 (0: 무제한, 2M context)
# OPENROUTER_MAX_TOKENS=30000
# OPENROUTER_MAX_INPUT_CHARS=0

# Kilo AI Gateway
# https://app.kilo.ai 에서 API 키 발급
KILO_API_KEY=your_kilo_api_key_here
# 사용할 Kilo 모델 (기본값: x-ai/grok-4.1-fast)
# 예제 모델: x-ai/grok-4.1-fast, deepseek/deepseek-chat, openai/gpt-4o-mini
# KILO_MODEL=x-ai/grok-4.1-fast
# 출력 토큰 한계 (최대 30000) / 입력 문자 수 한계 (0: 무제한, 2M context)
# KILO_MAX_TOKENS=30000
# KILO_MAX_INPUT_CHARS=0

# ===========================================
# 선택적 설정
# ===========================================

# Local LLM (Ollama) — API 키 불필요
# Ollama 서버 주소 (기본값: http://localhost:11434)
# OLLAMA_BASE_URL=http://192.168.0.96:11434
# 사용할 Ollama 모델명 (기본값: qwen35-35b-maxctx)
# OLLAMA_MODEL=qwen35-35b-maxctx
# 출력 토큰 한계 (기본값: 16000) / 입력 문자 수 한계 (0: 무제한)
# OLLAMA_MAX_TOKENS=16000
# OLLAMA_MAX_INPUT_CHARS=0
# Ollama Reasoning 수준: high, medium, low, none (기본값: none)
# OLLAMA_REASONING_EFFORT=none

# 기본 LLM 제공자 (glm, chatgpt, minimax, perplexity, grok, qwen-or, qwen-kilo, ollama)
# LLM_PROVIDER=glm

# API 타임아웃 (초)
# API_TIMEOUT=1200
