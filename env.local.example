# ==============================================================================
# 카카오톡 대화 분석기 - API 키 설정 (앱 v2.9.8, 2026-07-04)
# ==============================================================================
# 이 파일을 .env.local로 복사하고 API 키를 입력하세요.
# cp env.local.example .env.local
#
# 주의: .env.local 파일은 Git에 커밋되지 않습니다.
# ===========================================
# 아래 선택 항목은 full_config.py의 os.getenv()와 대응합니다. (# 으로 비활성 = 코드 기본값 사용)
#
# [입력 상한 계산]
#   max_input_chars ≈ (모델 컨텍스트 tokens − max_tokens) × 1.5 (한글 대화 근사)
#   0 = 앱에서 입력 자르기 안 함

# Z.AI GLM API — 모델: glm-5.2 (1M context, 최대 출력 128K tokens)
# https://www.z.ai 에서 API 키 발급
# 모델 ID: glm-5.2 (기본). Coding Plan 1M 명시: glm-5.2[1m]
ZAI_API_KEY=your_zai_api_key_here
# ZAI_MODEL=glm-5.2
# 한 응답 최대 출력 토큰 (코드 기본 32768, API 상한 131072)
# ZAI_MAX_TOKENS=32768
# 원본 대화 입력 문자 상한 (기본 1450848 = (1000000−32768)×1.5)
# ZAI_MAX_INPUT_CHARS=1450848

# OpenAI API — 모델: gpt-4o-mini
# https://platform.openai.com 에서 API 키 발급
# 컨텍스트: 128K tokens | 최대 출력: 16K tokens
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MAX_TOKENS=16384
# OPENAI_MAX_INPUT_CHARS=167424

# MiniMax API (기본 LLM) — 모델: MiniMax-M3
# https://www.minimax.io 에서 API 키 발급
# 컨텍스트: 최대 1M tokens (표준 요금 구간 512K, platform.minimax.io)
MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_MAX_TOKENS=32768
# MINIMAX_MAX_INPUT_CHARS=718848

# Perplexity API — 모델: sonar
# https://www.perplexity.ai 에서 API 키 발급
# 컨텍스트: 128K tokens (docs.perplexity.ai)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
# PERPLEXITY_MAX_TOKENS=16000
# PERPLEXITY_MAX_INPUT_CHARS=168000

# xAI Grok API — 모델: grok-4-1-fast-non-reasoning
# https://console.x.ai 에서 API 키 발급
# 컨텍스트: 2M tokens (xAI/서드파티 스펙)
XAI_API_KEY=your_xai_api_key_here
# XAI_MAX_TOKENS=16000
# XAI_MAX_INPUT_CHARS=0

# OpenRouter API
# https://openrouter.ai/keys 에서 API 키 발급
OPENROUTER_API_KEY=your_openrouter_api_key_here
# 사용할 OpenRouter 모델 (기본값: x-ai/grok-4.1-fast, 컨텍스트 2M tokens)
# OPENROUTER_MODEL=x-ai/grok-4.1-fast
# OPENROUTER_MAX_TOKENS=30000
# OPENROUTER_MAX_INPUT_CHARS=0

# Kilo AI Gateway
# https://app.kilo.ai 에서 API 키 발급
KILO_API_KEY=your_kilo_api_key_here
# 사용할 Kilo 모델 (기본값: x-ai/grok-4.1-fast, 컨텍스트 2M tokens)
# KILO_MODEL=x-ai/grok-4.1-fast
# KILO_MAX_TOKENS=30000
# KILO_MAX_INPUT_CHARS=0

# ===========================================
# 선택적 설정
# ===========================================

# Xiaomi MiMo API — 모델: mimo-v2.5-pro
# https://platform.xiaomimimo.com 에서 API 키 발급
# 컨텍스트: 1M tokens | 최대 출력: 128K tokens
#
# 종량제(sk-): https://api.xiaomimimo.com/v1
# Token Plan(tp-) 싱가포르 클러스터 (콘솔 표기):
#   OpenAI 호환:  https://token-plan-sgp.xiaomimimo.com/v1          ← 이 앱 사용
#   Anthropic 호환: https://token-plan-sgp.xiaomimimo.com/anthropic  (미사용)
# tp- 키 기본값은 token-plan-sgp. 다른 리전은 MIMO_BASE_URL로 지정.
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
# MIMO_MAX_TOKENS=32768
# MIMO_MAX_INPUT_CHARS=1450848

# Local LLM (Ollama) — API 키 불필요
# Ollama 서버 주소 (기본값: http://localhost:11434)
# OLLAMA_BASE_URL=http://192.168.0.96:11434
# 사용할 Ollama 모델명 (기본값: qwen35-35b-maxctx)
# OLLAMA_MODEL=qwen35-35b-maxctx
# OLLAMA_MAX_TOKENS=16000
# OLLAMA_MAX_INPUT_CHARS=0
# Ollama Reasoning 수준: high, medium, low, none (기본값: none)
# OLLAMA_REASONING_EFFORT=none

# 기본 LLM 제공자 (glm, chatgpt, minimax, perplexity, grok, qwen-or, qwen-kilo, mimo, ollama)
# LLM_PROVIDER=minimax

# HTTP 읽기 타임아웃 초 (기본 1200 = 20분, Config.DEFAULT_TIMEOUT)
# API_TIMEOUT=1200
